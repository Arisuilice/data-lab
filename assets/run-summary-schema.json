{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DataLabLiteRunSummary",
  "type": "object",
  "required": [
    "created_at",
    "goal",
    "task_level",
    "input_files",
    "generated_files",
    "outputs",
    "quality_gates",
    "warnings",
    "next_actions"
  ],
  "properties": {
    "created_at": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "task_level": {
      "type": "string",
      "enum": [
        "Quick",
        "Standard",
        "Expanded",
        "Project"
      ]
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "input_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "data_shape": {
      "type": "object"
    },
    "target": {
      "type": [
        "string",
        "null"
      ]
    },
    "task_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "split_strategy": {
      "type": [
        "string",
        "null"
      ]
    },
    "metrics": {
      "type": "object"
    },
    "best_model": {
      "type": [
        "string",
        "null"
      ]
    },
    "generated_files": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "required": [
              "path",
              "kind"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "kind": {
                "type": "string"
              },
              "purpose": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "quality_gates": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "boolean"
          },
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "key_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "execution_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string"
          },
          "observation": {
            "type": "string"
          },
          "decision": {
            "type": "string"
          },
          "next_action": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
